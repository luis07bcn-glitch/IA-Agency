# ─────────────────────────────────────────────────
#  Financial Analyzer — Variables de entorno
#  Copia este archivo a .env y rellena los valores
# ─────────────────────────────────────────────────

# FRED API Key (gratuita en https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=tu_api_key_aqui

# Telegram Bot (opcional pero recomendado — punto 4)
# 1. Habla con @BotFather en Telegram → /newbot → obtienes el token
# 2. Envía un mensaje a tu bot, luego visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates para obtener el chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alertas por email (opcional)
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
