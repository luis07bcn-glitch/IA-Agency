# ============================================================================
#  CONFIGURACION DEL PRODUCTO  (copia este archivo a .env y rellena los valores)
# ============================================================================
#  Reglas de oro:
#   - NUNCA subas el archivo .env real a internet ni a GitHub.
#   - Esta herramienta NO tiene login. NO la expongas a internet sin poner
#     autenticacion delante (un proxy con contrasena). Lo unico que debe ser
#     publico es el webhook firmado de WhatsApp.
# ============================================================================

# ---------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# ---------------------------------------------------------------------------
# En local, docker-compose levanta Postgres en el puerto 5433 de tu ordenador.
POSTGRES_USER=citas
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=citas
# Cadena de conexion que usa el backend. En local dejala tal cual.
DATABASE_URL=postgres://citas:cambia-esta-contrasena@localhost:5433/citas

# ---------------------------------------------------------------------------
# AGENTE DE IA (OpenRouter)  -- SOLO FALLBACK
# ---------------------------------------------------------------------------
# Lo NORMAL es configurar la API key y el modelo desde la pantalla "Agente"
# de la propia app. Estas variables solo se usan si no hay nada guardado.
OPENROUTER_API_KEY=
AGENT_MODEL=anthropic/claude-3.5-sonnet

# ---------------------------------------------------------------------------
# WHATSAPP (YCloud)  -- ESTO VA POR CODIGO/ENV, NO POR LA UI
# ---------------------------------------------------------------------------
# Lo configura una persona tecnica una sola vez al desplegar. No hay pantalla.
#   - YCLOUD_API_KEY: la clave de tu cuenta de YCloud (para ENVIAR mensajes).
#   - YCLOUD_WEBHOOK_SECRET: secreto para verificar que los mensajes entrantes
#     vienen de verdad de YCloud. SIN ESTO, el webhook RECHAZA todo (seguridad).
#   - YCLOUD_WHATSAPP_NUMBER: tu numero de WhatsApp Business en formato E.164.
YCLOUD_API_KEY=
YCLOUD_WEBHOOK_SECRET=
YCLOUD_WHATSAPP_NUMBER=+34600000000

# ---------------------------------------------------------------------------
# DATOS DE EJEMPLO
# ---------------------------------------------------------------------------
# true  -> la primera vez (BD vacia) crea el centro "Fisioterapia Bienestar"
#          con servicios, horarios, pacientes y conversaciones de ejemplo.
# false -> arranca con la base de datos completamente vacia.
SEED_DEMO_DATA=true

# ---------------------------------------------------------------------------
# PUERTOS Y URLS
# ---------------------------------------------------------------------------
# Backend (API). Lleva el prefijo global /api.
API_PORT=3001
# Origen permitido para el navegador (CORS). En local es el frontend.
WEB_ORIGIN=http://localhost:3000

# El frontend necesita saber donde esta la API. OJO: esta variable se "hornea"
# en el momento de construir el frontend, no se cambia despues en caliente.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Zona horaria por defecto del servidor (el centro tiene la suya en su config).
TZ=Europe/Madrid
